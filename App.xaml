<Application x:Class="MKVenomTool.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="ekoflash.xaml">

    <Application.Resources>
        <ResourceDictionary>

            <SolidColorBrush x:Key="NeCyan"      Color="#00E5FF"/>
            <SolidColorBrush x:Key="NeLime"      Color="#39FF6E"/>
            <SolidColorBrush x:Key="NeAmber"     Color="#FFB347"/>
            <SolidColorBrush x:Key="NeRed"       Color="#FF3B5C"/>
            <SolidColorBrush x:Key="NeViolet"    Color="#BF6EFF"/>
            <SolidColorBrush x:Key="NePink"      Color="#FF2D78"/>
            <SolidColorBrush x:Key="NeGreen"     Color="#1CE17A"/>

            <SolidColorBrush x:Key="NeCyanSoft"  Color="#1A00E5FF"/>
            <SolidColorBrush x:Key="NeRedSoft"   Color="#22FF3B5C"/>
            <SolidColorBrush x:Key="NeGreenSoft" Color="#221CE17A"/>

            <SolidColorBrush x:Key="BgRoot"      Color="#05070D"/>
            <SolidColorBrush x:Key="BgPanel"     Color="#0D1626"/>
            <SolidColorBrush x:Key="BgCard"      Color="#101B2F"/>
            <SolidColorBrush x:Key="BgInput"     Color="#0F1A2B"/>
            <SolidColorBrush x:Key="BgHover"     Color="#1F2D47"/>

            <SolidColorBrush x:Key="FgBright"    Color="#EAF4FF"/>
            <SolidColorBrush x:Key="FgMid"       Color="#88B4D8"/>
            <SolidColorBrush x:Key="FgDim"       Color="#2A3F5F"/>

            <SolidColorBrush x:Key="BorderNormal" Color="#2A3F5F"/>
            <SolidColorBrush x:Key="BorderAccent" Color="#3352BFFF"/>
            <SolidColorBrush x:Key="BorderGlow"   Color="#5500E5FF"/>

            <SolidColorBrush x:Key="StatusOk"    Color="#1CE17A"/>
            <SolidColorBrush x:Key="StatusErr"   Color="#FF4C78"/>
            <SolidColorBrush x:Key="StatusWarn"  Color="#FFB347"/>

            <Style TargetType="ScrollBar">
                <Setter Property="Width" Value="5"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Opacity" Value="0.4"/>
                <Style.Triggers>
                    <Trigger Property="Orientation" Value="Horizontal">
                        <Setter Property="Width" Value="Auto"/>
                        <Setter Property="Height" Value="5"/>
                    </Trigger>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Opacity" Value="1"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="ScrollViewer">
                <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
                <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            </Style>

            <Style TargetType="ToolTip">
                <Setter Property="Background" Value="{StaticResource BgPanel}"/>
                <Setter Property="Foreground" Value="{StaticResource NeCyan}"/>
                <Setter Property="BorderBrush" Value="{StaticResource NeCyan}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="10,5"/>
                <Setter Property="Placement" Value="Top"/>
                <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
                <Setter Property="FontSize" Value="11"/>
            </Style>

            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource FgBright}"/>
                <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
                <Setter Property="FontSize" Value="12"/>
            </Style>

            <Style TargetType="TextBox">
                <Setter Property="Background" Value="{StaticResource BgInput}"/>
                <Setter Property="Foreground" Value="{StaticResource FgBright}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderNormal}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="8,5"/>
                <Setter Property="FontFamily" Value="Consolas"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>

            <Style TargetType="CheckBox">
                <Setter Property="Foreground" Value="{StaticResource FgMid}"/>
                <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Cursor" Value="Hand"/>
            </Style>

            <Style TargetType="ProgressBar">
                <Setter Property="Height" Value="8"/>
                <Setter Property="Background" Value="{StaticResource BgCard}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Foreground" Value="{StaticResource NeCyan}"/>
            </Style>

            <Style TargetType="DataGrid">
                <Setter Property="Background" Value="{StaticResource BgInput}"/>
                <Setter Property="Foreground" Value="{StaticResource FgBright}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderNormal}"/>
                <Setter Property="GridLinesVisibility" Value="Horizontal"/>
                <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderNormal}"/>
                <Setter Property="VerticalGridLinesBrush" Value="{StaticResource BorderNormal}"/>
                <Setter Property="HeadersVisibility" Value="Column"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
