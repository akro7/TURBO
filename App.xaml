<Application x:Class="MKVenomTool.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    
    <Application.Resources>
        <ResourceDictionary>
            <SolidColorBrush x:Key="NeLime"      Color="#39FF6E"/>
            <SolidColorBrush x:Key="NeViolet"    Color="#BF6EFF"/>
            <SolidColorBrush x:Key="NeCyan"      Color="#00EEFF"/>
            <SolidColorBrush x:Key="NeAmber"     Color="#FFB347"/>
            <SolidColorBrush x:Key="NeRed"       Color="#FF3B5C"/>
            
            <SolidColorBrush x:Key="BgRoot"      Color="#05070D"/>
            <SolidColorBrush x:Key="FgBright"    Color="#DEE8F0"/>
            <SolidColorBrush x:Key="FgMid"       Color="#5A7090"/>

            <Style TargetType="ScrollBar">
                <Setter Property="Width" Value="8"/>
                <Setter Property="Background" Value="Transparent"/>
                <Style.Triggers>
                    <Trigger Property="Orientation" Value="Horizontal">
                        <Setter Property="Width" Value="Auto"/>
                        <Setter Property="Height" Value="8"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="ToolTip">
                <Setter Property="Background" Value="#0D1220"/>
                <Setter Property="Foreground" Value="{StaticResource NeCyan}"/>
                <Setter Property="BorderBrush" Value="{StaticResource NeCyan}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="8,4"/>
                <Setter Property="Placement" Value="Top"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
