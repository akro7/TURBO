<Grid Grid.Row="3" Margin="4,10,4,10">
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
    </Grid.ColumnDefinitions>

    <ProgressBar x:Name="MainProgress"
                 Height="18"
                 Minimum="0"
                 Maximum="100"
                 Value="0"
                 Foreground="{DynamicResource AccentBrush}"
                 Background="#1E2238"
                 BorderBrush="{DynamicResource BorderBrush}"
                 BorderThickness="1"/>

    <StackPanel Grid.Column="1"
                Orientation="Horizontal"
                Margin="12,0,0,0">

        <Button x:Name="FlashAllBtn"
                Width="130"
                Height="36"
                Margin="0,0,8,0"
                Content="FLASH ALL"
                Background="{DynamicResource AccentSoftBrush}"
                BorderBrush="{DynamicResource AccentBrush}"
                Foreground="#F3FBFF"
                Style="{StaticResource ActionButton}"
                Click="FlashAll_Click"/>

        <Button x:Name="CancelBtn"
                Width="95"
                Height="36"
                Content="CANCEL"
                Background="#442233"
                BorderBrush="#AA5577"
                Foreground="#FFE5EE"
                Style="{StaticResource ActionButton}"
