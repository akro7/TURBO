</Grid>

<Border Grid.Row="4"
        Margin="4,0,4,0"
        Background="#180F1F35"
        BorderBrush="{DynamicResource BorderBrush}"
        BorderThickness="1"
        CornerRadius="10"
        Padding="8">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="LOG OUTPUT"
                   FontSize="13"
                   FontWeight="Bold"
                   Foreground="{DynamicResource AccentBrush}"
                   Margin="0,0,0,6"/>

        <TextBox x:Name="LogBox"
                 Grid.Row="1"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 Background="#101826"
                 Foreground="#D7F1FF"
                 BorderThickness="0"
                 FontFamily="Consolas"
                 FontSize="11"
                 Padding="8"/>
    </Grid>
</Border>

</Grid>
</Border>
</Grid>
</Window>
