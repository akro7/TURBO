<Window x:Class="MKVenomTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EKOFLASH TURBO"
        Width="1420"
        Height="900"
        MinWidth="1200"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        Background="#05070D"
        Foreground="#DDE8F6"
        FontFamily="Consolas">

    <Window.Resources>
        <LinearGradientBrush x:Key="RootBg" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#05070D" Offset="0"/>
            <GradientStop Color="#071126" Offset="1"/>
        </LinearGradientBrush>

        <SolidColorBrush x:Key="PanelBg" Color="#06122A"/>
        <SolidColorBrush x:Key="PanelBorder" Color="#17528C"/>
        <SolidColorBrush x:Key="Accent" Color="#37CFFF"/>
        <SolidColorBrush x:Key="Accent2" Color="#2A9BD6"/>
        <SolidColorBrush x:Key="TextSoft" Color="#95BCE4"/>

        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{StaticResource Accent}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#081C3B"/>
            <Setter Property="Foreground" Value="#CBE8FF"/>
            <Setter Property="BorderBrush" Value="#1E5B96"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="ListView">
            <Setter Property="Background" Value="#071731"/>
            <Setter Property="Foreground" Value="#D7ECFF"/>
            <Setter Property="BorderBrush" Value="#1D4E80"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="ModeButton" TargetType="Button">
            <Setter Property="Background" Value="#0A1E3D"/>
            <Setter Property="Foreground" Value="#D7ECFF"/>
            <Setter Property="BorderBrush" Value="#1E5A96"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#113262"/>
                    <Setter Property="BorderBrush" Value="#35B2FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button" BasedOn="{StaticResource ModeButton}">
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>

        <Style x:Key="BrowseButton" TargetType="Button" BasedOn="{StaticResource ModeButton}">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>
    </Window.Resources>

    <Border Margin="6"
            Background="{StaticResource RootBg}"
            BorderBrush="#1A4B7A"
            BorderThickness="1.2"
            CornerRadius="10">

        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="180"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Grid Width="64" Height="64" Margin="0,0,12,0">
                        <Ellipse Fill="#0B2448" Stroke="#33D0FF" StrokeThickness="2"/>
                        <Ellipse Margin="6" Fill="#0A1B37" Stroke="#2B9BE2" StrokeThickness="1"/>
                        <TextBlock Text="MK" Foreground="#40D5FF" FontWeight="Bold" FontSize="26"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>

                    <StackPanel>
                        <TextBlock Text="MK VENOM TOOL" FontSize="52" FontWeight="Bold" Foreground="#33C8FF"/>
                        <TextBlock Text="Fastboot | Odin (ekoflash.exe) | ADB / Sideload | Tools"
                                   Foreground="{StaticResource TextSoft}" FontSize="19"/>
                        <TextBlock Text="by @MkProMVP" Foreground="#6D9ECB" FontSize="13"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8">
                        <TextBlock Text="Theme" Foreground="#8FBEEA" VerticalAlignment="Center" Margin="0,0,8,0"/>

                        <Button Width="26" Height="26" Tag="Blue" Click="Swatch_Click" BorderThickness="0" Margin="0,0,6,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Ellipse Fill="#45CFFF" Stroke="#BCEFFF" StrokeThickness="1"/>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Width="26" Height="26" Tag="Purple" Click="Swatch_Click" BorderThickness="0" Margin="0,0,6,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Ellipse Fill="#7561C8" Stroke="#D8D1FF" StrokeThickness="1"/>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Width="26" Height="26" Tag="Emerald" Click="Swatch_Click" BorderThickness="0" Margin="0,0,6,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Ellipse Fill="#2CA78B" Stroke="#BAF9E9" StrokeThickness="1"/>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Width="26" Height="26" Tag="Crimson" Click="Swatch_Click" BorderThickness="0" Margin="0,0,6,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Ellipse Fill="#A14575" Stroke="#F7C1DD" StrokeThickness="1"/>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Width="26" Height="26" Tag="Gold" Click="Swatch_Click" BorderThickness="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Ellipse Fill="#A67C2E" Stroke="#F6E0AE" StrokeThickness="1"/>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                    <Border BorderBrush="#1C568F" BorderThickness="1" CornerRadius="10" Padding="10,6">
                        <StackPanel Orientation="Horizontal">
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Text="DEVICE STATUS" Foreground="#7AC6FF" FontSize="12"/>
                                <TextBlock x:Name="DeviceStatusText" Text="Not checked" Foreground="#FFC94B" FontSize="24" FontWeight="SemiBold"/>
                            </StackPanel>
                            <Button Content="Detect Device"
                                    Style="{StaticResource ModeButton}"
                                    Padding="16,7"
                                    Margin="0"
                                    Click="DetectDevice_Click"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Modes -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                <Button Content="FASTBOOT MODE" Style="{StaticResource ModeButton}" Width="210" Click="FastbootMode_Click"/>
                <Button Content="ODIN MODE" Style="{StaticResource ModeButton}" Width="190" Click="OdinMode_Click"/>
                <Button Content="ADB SIDELOAD" Style="{StaticResource ModeButton}" Width="200" Click="SideloadMode_Click"/>
                <Button Content="ADB / TOOLS" Style="{StaticResource ModeButton}" Width="190" Click="ToolsMode_Click"/>
                <Button Content="BACKUP / RESTORE" Style="{StaticResource ModeButton}" Width="220" Click="BackupRestoreMode_Click"/>
            </StackPanel>

            <!-- Main -->
            <Grid Grid.Row="2" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="310"/>
                </Grid.ColumnDefinitions>

                <!-- Left big panel -->
                <GroupBox Header="PARTITION FLASHING" Grid.Column="0">
                    <Grid>
                        <!-- Fastboot -->
                        <Grid x:Name="PanelFastboot" Visibility="Visible">
                            <ListView x:Name="RowsList">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="74"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Label}" VerticalAlignment="Center" Foreground="#BCE0FF"/>
                                            <TextBox Grid.Column="1" Text="{Binding FilePath, Mode=TwoWay}" Margin="0,0,6,0"/>
                                            <Button Grid.Column="2" Content="Browse" Style="{StaticResource BrowseButton}" Tag="{Binding Key}" Click="FbBrowse_Click"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>

                        <!-- Odin -->
                        <Grid x:Name="PanelOdin" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBox x:Name="PitPathBox" Width="560" IsReadOnly="True"/>
                                <Button Content="Browse PIT" Style="{StaticResource BrowseButton}" Click="BrowsePit_Click" Margin="0,0,6,0"/>
                                <Button Content="Clear PIT" Style="{StaticResource BrowseButton}" Click="ClearPit_Click"/>
                            </StackPanel>

                            <ListView x:Name="OdinRowsList" Grid.Row="1">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="74"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Label}" VerticalAlignment="Center" Foreground="#BCE0FF"/>
                                            <TextBox Grid.Column="1" Text="{Binding FilePath, Mode=TwoWay}" Margin="0,0,6,0"/>
                                            <Button Grid.Column="2" Content="Browse" Style="{StaticResource BrowseButton}" Tag="{Binding Key}" Click="OdinBrowse_Click"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>

                        <!-- Sideload -->
                        <Grid x:Name="PanelSideload" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="ADB SIDELOAD ZIP" Foreground="#9FD0F9" Margin="0,0,0,6"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBox x:Name="SideloadPathBox" Width="650"/>
                                    <Button Content="Browse ZIP" Style="{StaticResource BrowseButton}" Click="SideloadBrowse_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <!-- Tools -->
                        <Grid x:Name="PanelTools" Visibility="Collapsed">
                            <WrapPanel>
                                <Button Content="Reboot System" Style="{StaticResource ModeButton}" Click="CmdRebootSys_Click"/>
                                <Button Content="Reboot Bootloader" Style="{StaticResource ModeButton}" Click="CmdRebootBl_Click"/>
                                <Button Content="Reboot Recovery" Style="{StaticResource ModeButton}" Click="CmdRebootRec_Click"/>
                                <Button Content="Launch Zadig" Style="{StaticResource ModeButton}" Click="LaunchZadig_Click"/>
                            </WrapPanel>
                        </Grid>

                        <!-- Backup -->
                        <Grid x:Name="PanelBackupRestore" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Load Apps" Style="{StaticResource BrowseButton}" Click="LoadApps_Click" Margin="0,0,6,0"/>
                                    <Button Content="Start Backup" Style="{StaticResource BrowseButton}" Click="StartBackup_Click"/>
                                </StackPanel>
                                <ListView x:Name="BackupAppsList" Height="320" Margin="0,8,0,0">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Package" Width="210" DisplayMemberBinding="{Binding PackageName}"/>
                                            <GridViewColumn Header="Name" Width="170" DisplayMemberBinding="{Binding DisplayName}"/>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                <ListView x:Name="BackupSetsList" Height="360">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Header="Package" Width="170" DisplayMemberBinding="{Binding PackageName}"/>
                                            <GridViewColumn Header="Path" Width="220" DisplayMemberBinding="{Binding BackupPath}"/>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </GroupBox>

                <!-- Right panel -->
                <GroupBox Header="Command / Options" Grid.Column="1" Margin="12,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="Command" Style="{StaticResource BrowseButton}" Click="TabCmd_Click" Margin="0,0,6,0"/>
                            <Button Content="Options" Style="{StaticResource BrowseButton}" Click="TabOptions_Click"/>
                        </StackPanel>

                        <Grid Grid.Row="1">
                            <Grid x:Name="TabCmdPanel" Visibility="Visible">
                                <StackPanel>
                                    <TextBlock Text="COMMAND PREVIEW" Foreground="#31C8FF" FontWeight="Bold" Margin="0,0,0,6"/>
                                    <TextBox x:Name="CommandPreviewBox"
                                             Height="320"
                                             Text="No command queued."
                                             IsReadOnly="True"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"/>
                                </StackPanel>
                            </Grid>

                            <Grid x:Name="TabOptionsPanel" Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="ODIN OPTIONS" Foreground="#31C8FF" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <CheckBox x:Name="RepartitionChk" Content="Re-partition" Foreground="#CBE8FF"/>
                                    <CheckBox x:Name="AutoRebootChk" Content="Auto reboot after flash" IsChecked="True" Foreground="#CBE8FF"/>
                                    <CheckBox x:Name="FResetTimeChk" Content="F. Reset Time" IsChecked="True" Foreground="#CBE8FF"/>
                                </StackPanel>
                            </Grid>
                        </Grid>

                        <Button Grid.Row="2"
                                Content="START FLASHING"
                                Style="{StaticResource ActionButton}"
                                Background="#1AA261"
                                BorderBrush="#4DDA96"
                                Foreground="White"
                                Click="StartFlashing_Click"
                                Margin="0,8,0,0"/>
                    </Grid>
                </GroupBox>
            </Grid>

            <!-- Actions -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="START FLASHING" Style="{StaticResource ActionButton}" Background="#1AA261" BorderBrush="#4DDA96" Foreground="White" Click="StartFlashing_Click"/>
                <Button Content="WIPE DATA" Style="{StaticResource ActionButton}" Background="#893252" BorderBrush="#C4688F"/>
                <Button Content="REBOOT SYSTEM" Style="{StaticResource ActionButton}" Background="#1E6588" BorderBrush="#4EA9DC"/>
                <Button Content="RESET ALL" Style="{StaticResource ActionButton}" Background="#2C3950" BorderBrush="#6A86AE"/>
            </StackPanel>

            <!-- Log -->
            <GroupBox Header="OPERATION LOG" Grid.Row="4">
                <TextBox x:Name="LogBox"
                         IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Background="#06142B"
                         Foreground="#E5F5FF"/>
            </GroupBox>
        </Grid>
    </Border>
</Window>
