<Window x:Class="MKVenomTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EKO FLASH PRO v3.0 · by AHMED YOUNIS &amp; MOHAMED KHALED PRO"
        Width="1420" Height="900"
        MinWidth="1200" MinHeight="750"
        WindowStartupLocation="CenterScreen"
        Background="#05070D" Foreground="#DEE8F0"
        FontFamily="Consolas">

    <Window.Resources>
        <SolidColorBrush x:Key="BgRoot"      Color="#05070D"/>
        <SolidColorBrush x:Key="BgSidebar"   Color="#080C14"/>
        <SolidColorBrush x:Key="BgPanel"     Color="#0A0E18"/>
        <SolidColorBrush x:Key="BgCard"      Color="#0D1220"/>
        <SolidColorBrush x:Key="BgEntry"     Color="#070B14"/>
        <SolidColorBrush x:Key="BgHdr"       Color="#060A12"/>
        <SolidColorBrush x:Key="BorderDim"   Color="#141E2E"/>
        <SolidColorBrush x:Key="BorderAct"   Color="#1E304A"/>

        <SolidColorBrush x:Key="NeLime"      Color="#39FF6E"/>
        <SolidColorBrush x:Key="NeViolet"    Color="#BF6EFF"/>
        <SolidColorBrush x:Key="NeAmber"     Color="#FFB347"/>
        <SolidColorBrush x:Key="NeCyan"      Color="#00EEFF"/>
        <SolidColorBrush x:Key="NeRed"       Color="#FF3B5C"/>
        <SolidColorBrush x:Key="FgBright"    Color="#DEE8F0"/>
        <SolidColorBrush x:Key="FgMid"       Color="#5A7090"/>
        <SolidColorBrush x:Key="FgDim"       Color="#1E2E40"/>

        <Style x:Key="GlassPanel" TargetType="Border">
            <Setter Property="Background" Value="#E60A0E18"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderAct}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10"/>
        </Style>

        <Style x:Key="NeonEntry" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BgEntry}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderDim}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource NeCyan}"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="NeonBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="BorderBrush" Value="{Binding Foreground, RelativeSource={RelativeSource Self}}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="4" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{Binding Foreground, RelativeSource={RelativeSource Self}}"/>
                                <Setter Property="Foreground" Value="#000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="QuickCmdBtn" TargetType="Button" BasedOn="{StaticResource NeonBtn}">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="BorderBrush" Value="{StaticResource FgDim}"/>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BgRoot}">
        <Canvas IsHitTestVisible="False">
            <Ellipse Canvas.Left="-150" Canvas.Top="-150" Width="450" Height="450" Fill="#1539FF6E">
                <Ellipse.Effect><BlurEffect Radius="130"/></Ellipse.Effect>
            </Ellipse>
            <Ellipse Canvas.Right="-150" Canvas.Bottom="-150" Width="450" Height="450" Fill="#15BF6EFF">
                <Ellipse.Effect><BlurEffect Radius="130"/></Ellipse.Effect>
            </Ellipse>
        </Canvas>

        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource BgSidebar}" BorderBrush="{StaticResource BorderAct}" BorderThickness="0,0,0,1">
                <Grid Margin="18,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="EKO" Foreground="{StaticResource NeLime}" FontSize="24" FontWeight="Bold"/>
                        <TextBlock Text=" FLASH " Foreground="{StaticResource FgBright}" FontSize="24" FontWeight="Bold"/>
                        <TextBlock Text="PRO" Foreground="{StaticResource NeViolet}" FontSize="24" FontWeight="Bold"/>
                        
                        <StackPanel Margin="20,6,0,0" VerticalAlignment="Center" Orientation="Horizontal">
                            <TextBlock Text="v3.0  ·  DEV: " Foreground="{StaticResource FgMid}" FontSize="12" Margin="0,2,0,0"/>
                            <TextBlock Text="AHMED YOUNIS" Foreground="{StaticResource NeAmber}" FontSize="14" FontWeight="Bold"/>
                            <TextBlock Text=" &amp; " Foreground="{StaticResource FgMid}" FontSize="14" FontWeight="Bold" Margin="4,0"/>
                            <TextBlock Text="MOHAMED KHALED PRO" Foreground="{StaticResource NeCyan}" FontSize="14" FontWeight="Bold"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderAct}" BorderThickness="1" Padding="12,6" Margin="0,0,10,0" CornerRadius="4">
                            <StackPanel>
                                <TextBlock Text="DEVICE" Foreground="{StaticResource FgMid}" FontSize="10" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="LblDeviceStatusTop" Text="◉  OFFLINE" Foreground="{StaticResource NeRed}" FontWeight="Bold" FontSize="14" Margin="0,3,0,0" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderAct}" BorderThickness="1" Padding="12,6" CornerRadius="4">
                            <StackPanel>
                                <TextBlock Text="MODE" Foreground="{StaticResource FgMid}" FontSize="10" HorizontalAlignment="Center"/>
                                <TextBlock Text="DUAL PANEL" Foreground="{StaticResource NeCyan}" FontWeight="Bold" FontSize="14" Margin="0,3,0,0" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="5*"/>
                    <ColumnDefinition Width="5*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource BgSidebar}" BorderBrush="{StaticResource BorderAct}" BorderThickness="0,0,1,0" Padding="15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,15">
                            <TextBlock Text="DEVICE STATS" Foreground="{StaticResource NeCyan}" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>
                            <Rectangle Height="1" Fill="{StaticResource NeCyan}" Margin="0,0,0,8"/>
                            
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Text="STATUS" Foreground="{StaticResource FgMid}" FontSize="11"/>
                                <TextBlock x:Name="LblStatStatus" Grid.Column="1" Text="OFFLINE" Foreground="{StaticResource NeRed}" FontWeight="Bold" FontSize="11"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Text="PROTOCOL" Foreground="{StaticResource FgMid}" FontSize="11"/>
                                <TextBlock x:Name="LblStatProtocol" Grid.Column="1" Text="—" Foreground="{StaticResource FgMid}" FontWeight="Bold" FontSize="11"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Text="SERIAL" Foreground="{StaticResource FgMid}" FontSize="11"/>
                                <TextBlock x:Name="LblStatSerial" Grid.Column="1" Text="—" Foreground="{StaticResource FgMid}" FontWeight="Bold" FontSize="11"/>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Margin="0,0,0,15">
                            <TextBlock Text="QUICK CMD" Foreground="{StaticResource NeAmber}" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>
                            <Rectangle Height="1" Fill="{StaticResource BorderAct}" Margin="0,0,0,8"/>
                            
                            <Button Content="▶ REBOOT SYS" Style="{StaticResource QuickCmdBtn}" Foreground="{StaticResource NeLime}" Click="CmdRebootSys_Click"/>
                            <Button Content="▶ REBOOT BL" Style="{StaticResource QuickCmdBtn}" Foreground="{StaticResource NeAmber}" Click="CmdRebootBl_Click"/>
                            <Button Content="▶ REBOOT REC" Style="{StaticResource QuickCmdBtn}" Foreground="{StaticResource NeCyan}" Click="CmdRebootRec_Click"/>
                            <Button Content="▶ ADB SIDELOAD" Style="{StaticResource QuickCmdBtn}" Foreground="{StaticResource NeViolet}" Click="CmdAdbSideload_Click"/>
                            <Button Content="▶ WIPE DATA" Style="{StaticResource QuickCmdBtn}" Foreground="{StaticResource NeRed}" Click="CmdWipeData_Click"/>
                            <Button Content="▶ ERASE SYSTEM" Style="{StaticResource QuickCmdBtn}" Foreground="{StaticResource NeRed}" Click="CmdEraseSystem_Click"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2">
                            <Rectangle Height="1" Fill="{StaticResource BorderAct}" Margin="0,0,0,8"/>
                            <CheckBox x:Name="ChkAutoReboot" Content=" Auto-Reboot" Foreground="{StaticResource FgMid}" IsChecked="True" Margin="0,0,0,12"/>
                            
                            <Rectangle Height="1" Fill="{StaticResource BorderAct}" Margin="0,0,0,8"/>
                            <Button Content="CLEAR LOGS" Style="{StaticResource NeonBtn}" Foreground="{StaticResource NeRed}" HorizontalAlignment="Stretch" Padding="8,6" Click="CmdClearLogs_Click"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3" VerticalAlignment="Bottom">
                            <Rectangle Height="1" Fill="{StaticResource BorderAct}" Margin="0,0,0,8"/>
                            <TextBlock Text="ENGINE: ekoflash.exe" Foreground="{StaticResource FgDim}" FontSize="10" TextWrapping="Wrap" Margin="0,0,0,8"/>
                            <Rectangle Height="1" Fill="{StaticResource BorderAct}" Margin="0,0,0,8"/>
                            <TextBlock Text="© 2026 AKRO" Foreground="{StaticResource FgDim}" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="140"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource BgHdr}" Padding="10,6" CornerRadius="4,4,0,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text=" ⚡ " Background="{StaticResource NeLime}" Foreground="#000000" FontWeight="Bold" Padding="2"/>
                            <TextBlock DockPanel.Dock="Left" Text="  FASTBOOT PARTITION FLASH" Foreground="{StaticResource NeLime}" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock DockPanel.Dock="Right" Text="fastboot.exe" Foreground="{StaticResource FgDim}" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource GlassPanel}" CornerRadius="0,0,4,4" Margin="0,0,0,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="130"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="#" Foreground="{StaticResource FgMid}" FontSize="11"/>
                                <TextBlock Grid.Column="1" Text="PARTITION" Foreground="{StaticResource FgMid}" FontSize="11"/>
                                <TextBlock Grid.Column="2" Text="IMAGE FILE PATH" Foreground="{StaticResource FgMid}" FontSize="11"/>
                                <Rectangle Grid.ColumnSpan="4" Height="1" Fill="{StaticResource NeLime}" VerticalAlignment="Bottom" Margin="0,18,0,0"/>
                            </Grid>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="FastbootRowsList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="30"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="70"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Index}" Foreground="{StaticResource FgDim}" FontSize="11" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Partition}" Foreground="{Binding AccentColor}" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="2" Text="{Binding FilePath, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NeonEntry}" Foreground="{Binding AccentColor}" Margin="0,0,8,0"/>
                                                <Button Grid.Column="3" Content="BRW" Style="{StaticResource NeonBtn}" Foreground="{StaticResource NeAmber}" Margin="0,0,4,0" Tag="{Binding Partition}" Click="FbBrowse_Click"/>
                                                <Button Grid.Column="4" Content="FLASH" Style="{StaticResource NeonBtn}" Foreground="{Binding AccentColor}" Tag="{Binding Partition}" Click="FbFlash_Click"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <StackPanel Grid.Row="2">
                                <Rectangle Height="1" Fill="{StaticResource NeLime}" Margin="0,5,0,8"/>
                                <Button Content="⚡ FLASH ALL SELECTED" Style="{StaticResource NeonBtn}" Foreground="{StaticResource NeLime}" HorizontalAlignment="Left" Width="200" Click="FbFlashAll_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TextBlock Grid.Row="2" Text="FASTBOOT LOG" Foreground="{StaticResource NeLime}" FontSize="11" Margin="2,0,0,4"/>
                    <TextBox x:Name="FastbootLogBox" Grid.Row="3" Background="{StaticResource BgEntry}" Foreground="{StaticResource NeLime}" BorderBrush="{StaticResource BorderDim}" BorderThickness="1" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" Padding="8"/>
                </Grid>

                <Grid Grid.Column="2" Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="140"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource BgHdr}" Padding="10,6" CornerRadius="4,4,0,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text=" ◈ " Background="{StaticResource NeViolet}" Foreground="#000000" FontWeight="Bold" Padding="2"/>
                            <TextBlock DockPanel.Dock="Left" Text="  ODIN ENGINE CORE FLASH" Foreground="{StaticResource NeViolet}" FontWeight="Bold" VerticalAlignment="Center"/>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                <ProgressBar x:Name="OdinProgressBar" Width="120" Height="10" Background="{StaticResource BgEntry}" Foreground="{StaticResource NeViolet}" BorderThickness="0" Maximum="100" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="LblOdinPercent" Text="0%" Foreground="{StaticResource NeViolet}" FontSize="11" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                <TextBlock Text="ekoflash" Foreground="{StaticResource FgDim}" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource GlassPanel}" CornerRadius="0,0,4,4" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="220"/>
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0" Margin="0,0,10,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="130"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="✓" Foreground="{StaticResource FgMid}" FontSize="11" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="SLOT" Foreground="{StaticResource FgMid}" FontSize="11"/>
                                    <TextBlock Grid.Column="2" Text="BINARY FILE PATH" Foreground="{StaticResource FgMid}" FontSize="11"/>
                                    <Rectangle Grid.ColumnSpan="4" Height="1" Fill="{StaticResource NeViolet}" VerticalAlignment="Bottom" Margin="0,18,0,0"/>
                                </Grid>

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="OdinRowsList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="30"/>
                                                        <ColumnDefinition Width="70"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="60"/>
                                                        <ColumnDefinition Width="70"/>
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox IsChecked="{Binding IsChecked}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                    <Border Grid.Column="1" Background="{Binding AccentColor}" Padding="4,2" Margin="0,0,8,0" CornerRadius="2">
                                                        <TextBlock Text="{Binding SlotName}" Foreground="#000000" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center"/>
                                                    </Border>
                                                    <TextBox Grid.Column="2" Text="{Binding FilePath, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource NeonEntry}" Foreground="{Binding AccentColor}" Margin="0,0,8,0"/>
                                                    <Button Grid.Column="3" Content="SELECT" Style="{StaticResource NeonBtn}" Foreground="{Binding AccentColor}" Margin="0,0,4,0" Tag="{Binding SlotName}" Click="OdinBrowse_Click"/>
                                                    <Button Grid.Column="4" Content="FLASH" Style="{StaticResource NeonBtn}" Foreground="{Binding AccentColor}" Tag="{Binding SlotName}" Click="OdinFlashSingle_Click"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <!-- ✅ FIX: removed Padding="0,5" from Grid, added Margin to inner StackPanel instead -->
                                <Grid Grid.Row="2" Background="{StaticResource BgPanel}" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="134"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="1" Background="{StaticResource NeAmber}" Padding="4,2" Margin="0,5,8,5" CornerRadius="2">
                                        <TextBlock Text="PIT" Foreground="#000000" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center"/>
                                    </Border>
                                    <TextBox x:Name="TxtPitPath" Grid.Column="2" Style="{StaticResource NeonEntry}" Foreground="{StaticResource NeAmber}" Margin="0,5,8,5"/>
                                    <Button Grid.Column="3" Content="SELECT" Style="{StaticResource NeonBtn}" Foreground="{StaticResource NeAmber}" HorizontalAlignment="Left" Width="60" Margin="0,5,0,5" Click="OdinBrowsePit_Click"/>
                                </Grid>

                                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,15,0,0">
                                    <Button Content="▶  START ENGINE FLASH" Style="{StaticResource NeonBtn}" Foreground="{StaticResource NeViolet}" Width="200" Margin="0,0,8,0" Click="OdinStartFlash_Click"/>
                                    <Button Content="⊗ RESET" Style="{StaticResource NeonBtn}" Foreground="{StaticResource NeRed}" Width="80" Click="OdinReset_Click"/>
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <Border Grid.Row="0" BorderBrush="{StaticResource BorderAct}" BorderThickness="1" Background="{StaticResource BgEntry}" CornerRadius="4" Padding="10,15" Margin="0,0,0,10">
                                    <TextBlock x:Name="LblPassFail" Text="READY" Foreground="{StaticResource FgMid}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Row="1">
                                    <TextBlock Text="OPTIONS" Foreground="{StaticResource NeAmber}" FontSize="11" Margin="2,0,0,8"/>
                                    <Rectangle Height="1" Fill="{StaticResource BorderAct}" Margin="0,0,0,8"/>
                                    <CheckBox x:Name="OptAutoReboot" Content="Auto Reboot" Foreground="{StaticResource FgMid}" IsChecked="True" Margin="0,0,0,6"/>
                                    <CheckBox x:Name="OptNandErase" Content="Nand Erase" Foreground="{StaticResource FgMid}" Margin="0,0,0,6"/>
                                    <CheckBox x:Name="OptRePartition" Content="Re-Partition" Foreground="{StaticResource FgMid}" Margin="0,0,0,6"/>
                                    <CheckBox x:Name="OptFResetTime" Content="F. Reset Time" Foreground="{StaticResource FgMid}" IsChecked="True" Margin="0,0,0,6"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <TextBlock Grid.Row="2" Text="ENGINE LOG" Foreground="{StaticResource NeViolet}" FontSize="11" Margin="2,0,0,4"/>
                    <TextBox x:Name="OdinLogBox" Grid.Row="3" Background="{StaticResource BgEntry}" Foreground="{StaticResource NeViolet}" BorderBrush="{StaticResource BorderDim}" BorderThickness="1" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" Padding="8"/>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
