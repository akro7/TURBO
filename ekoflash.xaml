<Window x:Class="MKVenomTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EKOFLASH TURBO"
        Width="1360"
        Height="860"
        MinWidth="1180"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="#080B12"
        Foreground="#E6EEF9"
        FontFamily="Consolas">

    <Window.Resources>
        <SolidColorBrush x:Key="BgRoot" Color="#080B12"/>
        <SolidColorBrush x:Key="BgPanel" Color="#0D1420"/>
        <SolidColorBrush x:Key="BgCard" Color="#121B2A"/>
        <SolidColorBrush x:Key="BorderBrushMain" Color="#22334D"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#37CFFF"/>
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#305A89"/>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="Foreground" Value="#CFE8FF"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushMain}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0B121E"/>
            <Setter Property="Foreground" Value="#BFE9FF"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushMain}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CDE3FF"/>
            <Setter Property="Margin" Value="0,0,10,8"/>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BgRoot}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="62"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top -->
        <Border Grid.ColumnSpan="2" Grid.Row="0" Background="#0D1420" BorderBrush="{StaticResource BorderBrushMain}" BorderThickness="0,0,0,1">
            <Grid Margin="14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="EKOFLASH TURBO" FontSize="20" FontWeight="Bold" Foreground="#8BE2FF" Margin="0,0,14,0"/>
                    <TextBlock Text="Odin Engine: ekoflash.exe" Foreground="#A4CFFF" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Detect Device" Click="DetectDevice_Click"/>
                    <Button Content="Start Flashing" Background="{StaticResource AccentBrush}" Foreground="#001426" BorderBrush="{StaticResource AccentBrush}" Click="StartFlashing_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Sidebar -->
        <Border Grid.Column="0" Grid.Row="1" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderBrushMain}" BorderThickness="0,0,1,0">
            <StackPanel Margin="12">
                <TextBlock Text="MODE" Foreground="#8FAED1" Margin="4,0,0,8"/>
                <Button Content="Fastboot" Click="FastbootMode_Click"/>
                <Button Content="Odin (ekoflash.exe)" Click="OdinMode_Click"/>
                <Button Content="Sideload" Click="SideloadMode_Click"/>
                <Button Content="Tools" Click="ToolsMode_Click"/>
                <Button Content="Backup / Restore" Click="BackupRestoreMode_Click"/>

                <Separator Margin="0,8"/>

                <TextBlock Text="TAB" Foreground="#8FAED1" Margin="4,2,0,8"/>
                <Button Content="Commands" Click="TabCmd_Click"/>
                <Button Content="Options" Click="TabOptions_Click"/>

                <Separator Margin="0,8"/>

                <TextBlock Text="Theme" Foreground="#8FAED1" Margin="4,2,0,8"/>
                <StackPanel Orientation="Horizontal">
                    <Button Width="52" Content="Blue" Tag="Blue" Click="Swatch_Click"/>
                    <Button Width="52" Content="Purple" Tag="Purple" Click="Swatch_Click"/>
                    <Button Width="62" Content="Emerald" Tag="Emerald" Click="Swatch_Click"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Button Width="52" Content="Gold" Tag="Gold" Click="Swatch_Click"/>
                    <Button Width="62" Content="Crimson" Tag="Crimson" Click="Swatch_Click"/>
                </StackPanel>

                <Separator Margin="0,8"/>
                <TextBlock x:Name="DeviceStatusText" Text="Device: Unknown" Foreground="#8FAED1" Margin="4,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Main -->
        <Grid Grid.Column="1" Grid.Row="1" Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="180"/>
            </Grid.RowDefinitions>

            <!-- Content area -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="380"/>
                </Grid.ColumnDefinitions>

                <!-- Left views -->
                <Border Grid.Column="0" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderBrushMain}" BorderThickness="1" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Operation Panel" FontSize="16" FontWeight="Bold" Foreground="#A8DBFF" Margin="0,0,0,10"/>

                        <Grid Grid.Row="1">
                            <!-- Fastboot -->
                            <Grid x:Name="PanelFastboot" Visibility="Visible">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Fastboot Partitions" Foreground="#95B8E0" Margin="0,0,0,8"/>
                                <ListView x:Name="RowsList" Grid.Row="1" Background="#0B121E" BorderBrush="{StaticResource BorderBrushMain}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="90"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="84"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Label}" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="1" Text="{Binding FilePath, Mode=TwoWay}" Margin="0,0,8,0"/>
                                                <Button Grid.Column="2" Content="Browse" Tag="{Binding Key}" Click="FbBrowse_Click" Margin="0"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>

                            <!-- Odin -->
                            <Grid x:Name="PanelOdin" Visibility="Collapsed">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Odin Engine: ekoflash.exe" Foreground="#95B8E0" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBox x:Name="PitPathBox" Width="420" IsReadOnly="True"/>
                                        <Button Content="PIT" Click="BrowsePit_Click"/>
                                        <Button Content="Clear PIT" Click="ClearPit_Click"/>
                                    </StackPanel>
                                </StackPanel>
                                <ListView x:Name="OdinRowsList" Grid.Row="1" Background="#0B121E" BorderBrush="{StaticResource BorderBrushMain}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="90"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="84"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Label}" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="1" Text="{Binding FilePath, Mode=TwoWay}" Margin="0,0,8,0"/>
                                                <Button Grid.Column="2" Content="Browse" Tag="{Binding Key}" Click="OdinBrowse_Click" Margin="0"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>

                            <!-- Sideload -->
                            <Grid x:Name="PanelSideload" Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="ADB Sideload" Foreground="#95B8E0" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBox x:Name="SideloadPathBox" Width="520"/>
                                        <Button Content="Browse ZIP" Click="SideloadBrowse_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <!-- Tools -->
                            <Grid x:Name="PanelTools" Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="Tools" Foreground="#95B8E0" Margin="0,0,0,8"/>
                                    <Button Content="Reboot System" Click="CmdRebootSys_Click" Width="160"/>
                                    <Button Content="Reboot Bootloader" Click="CmdRebootBl_Click" Width="160"/>
                                    <Button Content="Reboot Recovery" Click="CmdRebootRec_Click" Width="160"/>
                                    <Button Content="Launch Zadig" Click="LaunchZadig_Click" Width="160"/>
                                </StackPanel>
                            </Grid>

                            <!-- Backup -->
                            <Grid x:Name="PanelBackupRestore" Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="Installed Apps" Foreground="#95B8E0" Margin="0,0,0,8"/>
                                    <Button Content="Load Apps" Click="LoadApps_Click" Width="120"/>
                                    <ListView x:Name="BackupAppsList" Height="320" Background="#0B121E" BorderBrush="{StaticResource BorderBrushMain}">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="Package" DisplayMemberBinding="{Binding PackageName}" Width="200"/>
                                                <GridViewColumn Header="Name" DisplayMemberBinding="{Binding DisplayName}" Width="160"/>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                    <Button Content="Start Backup" Click="StartBackup_Click" Width="120"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="Backup Sets" Foreground="#95B8E0" Margin="0,0,0,8"/>
                                    <ListView x:Name="BackupSetsList" Height="380" Background="#0B121E" BorderBrush="{StaticResource BorderBrushMain}">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="Package" DisplayMemberBinding="{Binding PackageName}" Width="200"/>
                                                <GridViewColumn Header="Path" DisplayMemberBinding="{Binding BackupPath}" Width="220"/>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Right panel -->
                <Border Grid.Column="1" Margin="12,0,0,0" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderBrushMain}" BorderThickness="1" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Tab Area" FontSize="16" FontWeight="Bold" Foreground="#A8DBFF" Margin="0,0,0,10"/>

                        <Grid Grid.Row="1">
                            <Grid x:Name="TabCmdPanel" Visibility="Visible">
                                <StackPanel>
                                    <TextBlock Text="Command Preview" Foreground="#95B8E0" Margin="0,0,0,8"/>
                                    <TextBox x:Name="CommandPreviewBox" Height="120" TextWrapping="Wrap" AcceptsReturn="True" IsReadOnly="True"/>
                                </StackPanel>
                            </Grid>

                            <Grid x:Name="TabOptionsPanel" Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="Odin Options" Foreground="#95B8E0" Margin="0,0,0,8"/>
                                    <CheckBox x:Name="RepartitionChk" Content="Re-Partition"/>
                                    <CheckBox x:Name="AutoRebootChk" Content="Auto Reboot" IsChecked="True"/>
                                    <CheckBox x:Name="FResetTimeChk" Content="F. Reset Time" IsChecked="True"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- Log -->
            <Border Grid.Row="1" Margin="0,12,0,0" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderBrushMain}" BorderThickness="1" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Log" FontSize="15" FontWeight="Bold" Foreground="#A8DBFF" Margin="0,0,0,8"/>
                    <TextBox x:Name="LogBox"
                             Grid.Row="1"
                             Background="#0B121E"
                             Foreground="#9DE7FF"
                             BorderBrush="{StaticResource BorderBrushMain}"
                             BorderThickness="1"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             IsReadOnly="True"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
