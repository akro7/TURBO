<Window x:Class="MKVenomTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TURBO FLASH TOOL"
        Width="1340"
        Height="860"
        MinWidth="1150"
        MinHeight="750"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgRoot}">

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource BgPanel}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Vertical">
                    <TextBlock FontSize="18" FontWeight="Bold" Text="TURBO FLASH TOOL"/>
                    <TextBlock Foreground="{DynamicResource TextMutedBrush}"
                               Text="Fastboot / Odin / Sideload / Tools"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <ComboBox x:Name="ThemeCombo" Width="120" Margin="0,0,8,0">
                        <ComboBoxItem Content="Classic"/>
                        <ComboBoxItem Content="LiquidGlass"/>
                        <ComboBoxItem Content="Material"/>
                    </ComboBox>

                    <ComboBox x:Name="ModeCombo" Width="100" Margin="0,0,8,0">
                        <ComboBoxItem Content="Dark"/>
                        <ComboBoxItem Content="Light"/>
                    </ComboBox>

                    <ComboBox x:Name="AccentCombo" Width="100" Margin="0,0,8,0">
                        <ComboBoxItem Content="Cyan"/>
                        <ComboBoxItem Content="Violet"/>
                        <ComboBoxItem Content="Blue"/>
                        <ComboBoxItem Content="Green"/>
                        <ComboBoxItem Content="Orange"/>
                        <ComboBoxItem Content="Red"/>
                        <ComboBoxItem Content="Pink"/>
                    </ComboBox>

                    <Button Content="Apply Theme" Style="{StaticResource PrimaryButton}" Click="ApplyTheme_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Body -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Sidebar -->
            <Border Grid.Column="0"
                    Background="{DynamicResource BgPanel}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="12">
                <StackPanel>
                    <Button x:Name="FastbootBtn" Style="{StaticResource ModeButton}" Content="Fastboot" Click="FastbootMode_Click"/>
                    <Button x:Name="OdinBtn" Style="{StaticResource ModeButton}" Content="Odin" Click="OdinMode_Click"/>
                    <Button x:Name="SideloadBtn" Style="{StaticResource ModeButton}" Content="Sideload" Click="SideloadMode_Click"/>
                    <Button x:Name="ToolsBtn" Style="{StaticResource ModeButton}" Content="Tools" Click="ToolsMode_Click"/>

                    <Separator Margin="0,10,0,10"/>

                    <Button Content="Detect Device" Click="DetectDevice_Click"/>
                    <TextBlock Margin="0,8,0,0" Text="Device Status"/>
                    <TextBlock x:Name="DeviceStatusText" FontWeight="Bold" Text="NOT CHECKED"/>

                    <Separator Margin="0,10,0,10"/>

                    <Button x:Name="TabCmdBtn" Content="Command Tab" Click="TabCmd_Click"/>
                    <Button x:Name="TabOptionsBtn" Content="Options Tab" Click="TabOptions_Click"/>
                </StackPanel>
            </Border>

            <!-- Right Content -->
            <Border Grid.Column="2"
                    Background="{DynamicResource BgPanel}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="150"/>
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="16" FontWeight="Bold" Text="Operations"/>

                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Command / Options switch -->
                        <Grid>
                            <!-- Cmd panel -->
                            <Grid x:Name="TabCmdPanel">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Fastboot -->
                                <Grid x:Name="PanelFastboot">
                                    <DataGrid x:Name="RowsList" AutoGenerateColumns="False" CanUserAddRows="False">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Partition" Binding="{Binding Label}" Width="120"/>
                                            <DataGridTextColumn Header="File Path" Binding="{Binding FilePath}" Width="*"/>
                                            <DataGridTemplateColumn Header="Browse" Width="90">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Content="Browse" Tag="{Binding Key}" Click="Browse_Click"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="Flash One" Width="100">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Content="Flash" Tag="{Binding Key}" Click="FlashOne_Click"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>

                                <!-- Odin -->
                                <Grid x:Name="PanelOdin" Visibility="Collapsed">
                                    <DataGrid x:Name="OdinRowsList" AutoGenerateColumns="False" CanUserAddRows="False">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Slot" Binding="{Binding Label}" Width="100"/>
                                            <DataGridTextColumn Header="File Path" Binding="{Binding FilePath}" Width="*"/>
                                            <DataGridTemplateColumn Header="Browse" Width="90">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Content="Browse" Tag="{Binding Key}" Click="Browse_Click"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>

                                <!-- Sideload -->
                                <Grid x:Name="PanelSideload" Visibility="Collapsed">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="Select OTA ZIP file" FontWeight="Bold"/>
                                    <DockPanel Grid.Row="2">
                                        <TextBox x:Name="SideloadPathBox" Margin="0,0,8,0"/>
                                        <Button DockPanel.Dock="Right" Width="100" Content="Browse" Tag="sideload" Click="Browse_Click"/>
                                    </DockPanel>
                                </Grid>

                                <!-- Tools -->
                                <Grid x:Name="PanelTools" Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock Text="Quick Commands" FontWeight="Bold"/>
                                        <WrapPanel Margin="0,8,0,0">
                                            <Button Content="ADB Devices" Tag="adb devices" Click="QuickCmd_Click"/>
                                            <Button Content="Fastboot Devices" Tag="fastboot devices" Click="QuickCmd_Click"/>
                                            <Button Content="Reboot Bootloader" Tag="adb reboot bootloader" Click="QuickCmd_Click"/>
                                            <Button Content="Reboot Recovery" Tag="adb reboot recovery" Click="QuickCmd_Click"/>
                                        </WrapPanel>
                                    </StackPanel>
                                </Grid>

                                <TextBox Grid.Row="2"
                                         x:Name="CommandPreviewBox"
                                         Height="80"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"/>
                            </Grid>

                            <!-- Options panel -->
                            <Grid x:Name="TabOptionsPanel" Visibility="Collapsed">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Options" FontWeight="Bold"/>

                                <CheckBox x:Name="AutoRebootCheck"
                                          Grid.Row="2"
                                          Content="Auto Reboot after success"
                                          IsChecked="True"
                                          Foreground="{DynamicResource FgBright}"/>

                                <CheckBox x:Name="VerifyCheck"
                                          Grid.Row="4"
                                          Content="Verify before flashing"
                                          IsChecked="False"
                                          Foreground="{DynamicResource FgBright}"/>
                            </Grid>
                        </Grid>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="StopBtn" Content="Stop" Click="Stop_Click"/>
                            <Button x:Name="FlashAllBtn" Content="Flash All" Style="{StaticResource PrimaryButton}" Click="FlashAll_Click"/>
                        </StackPanel>
                    </Grid>

                    <TextBox Grid.Row="4"
                             x:Name="LogBox"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="4"
                Background="{DynamicResource BgPanel}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="ProgressStatusText" Text="Ready." VerticalAlignment="Center"/>
                <ProgressBar x:Name="MainProgress"
                             Grid.Column="1"
                             Height="16"
                             Minimum="0"
                             Maximum="100"
                             Value="0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
