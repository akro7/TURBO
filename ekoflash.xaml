<Window x:Class="MKVenomTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TURBO FLASH TOOL"
        Width="1340" Height="860"
        MinWidth="1100" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="#08101E" Foreground="#EAF4FF"
        FontFamily="Segoe UI">

    <Window.Resources>
        <SolidColorBrush x:Key="MainBgBrush" Color="#08101E"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#3A0D1B33"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#4C52BFFF"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#37CFFF"/>
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#7A35CFFF"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#5AFF4C78"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#5A1CE17A"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#FFC857"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#9CC7E8"/>

        <Style x:Key="GlassPanel" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PanelBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="13"/>
            <Setter Property="Padding" Value="12"/>
        </Style>

        <Style x:Key="ModeButton" TargetType="Button">
            <Setter Property="Foreground" Value="#D6E9FF"/>
            <Setter Property="Background" Value="#2D18253D"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Margin" Value="0,0,7,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="2,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PathBox" TargetType="TextBox">
            <Setter Property="Background" Value="#2C132443"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#EAF4FF"/>
            <Setter Property="Padding" Value="7,5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="BrowseBtn" TargetType="Button">
            <Setter Property="Background" Value="#36FFFFFF"/>
            <Setter Property="BorderBrush" Value="#66FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#F4FAFF"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FlashBtn" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#E9F7FF"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="2,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="FastbootRowTemplate">
            <Border Style="{StaticResource GlassPanel}" Margin="0,0,0,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="70"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding Label}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentBrush}"
                               VerticalAlignment="Center"
                               FontSize="13"/>

                    <TextBox Grid.Column="1"
                             Style="{StaticResource PathBox}"
                             Text="{Binding FilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             IsReadOnly="True"
                             Margin="6,0"/>

                    <Button Grid.Column="2"
                            Style="{StaticResource BrowseBtn}"
                            Content="📂"
                            Tag="{Binding Key}"
                            Height="28" Width="60"
                            Click="Browse_Click"
                            Margin="0,0,4,0"/>

                    <Button Grid.Column="3"
                            Style="{StaticResource FlashBtn}"
                            Content="⚡"
                            Tag="{Binding Key}"
                            Height="28" Width="60"
                            Click="FlashOne_Click"/>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="OdinRowTemplate">
            <Border Style="{StaticResource GlassPanel}" Margin="0,0,0,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="70"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding Label}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentBrush}"
                               VerticalAlignment="Center"
                               FontSize="13"/>

                    <TextBox Grid.Column="1"
                             Style="{StaticResource PathBox}"
                             Text="{Binding FilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             IsReadOnly="True"
                             Margin="6,0"/>

                    <Button Grid.Column="2"
                            Style="{StaticResource BrowseBtn}"
                            Content="📂"
                            Tag="{Binding Key}"
                            Height="28" Width="60"
                            Click="Browse_Click"/>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Background="{StaticResource MainBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="180"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#0A1525"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Vertical">
                    <TextBlock Text="⚡ MK VENOM TOOL"
                               FontSize="22"
                               FontWeight="Black"
                               Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="TURBO FLASH TOOL v1.0  •  Developed by: AHMED YOUNIS &amp; Mohamed Khaled"
                               FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"
                               Margin="0,3,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="THEME:"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <Button Style="{StaticResource ActionButton}"
                            Background="#1A00E5FF"
                            BorderBrush="#00E5FF"
                            Foreground="#00E5FF"
                            Content="● Blue"
                            Tag="Blue"
                            Margin="0,0,6,0"
                            Padding="10,5"
                            Click="Swatch_Click"/>
                    <Button Style="{StaticResource ActionButton}"
                            Background="#1AB67BFF"
                            BorderBrush="#B67BFF"
                            Foreground="#B67BFF"
                            Content="● Purple"
                            Tag="Purple"
                            Margin="0,0,6,0"
                            Padding="10,5"
                            Click="Swatch_Click"/>
                    <Button Style="{StaticResource ActionButton}"
                            Background="#1AFF0055"
                            BorderBrush="#FF0055"
                            Foreground="#FF0055"
                            Content="● Crimson"
                            Tag="Crimson"
                            Padding="10,5"
                            Click="Swatch_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="#0C1828"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button x:Name="FastbootBtn"
                            Style="{StaticResource ModeButton}"
                            Content="🔷 FASTBOOT"
                            Click="FastbootMode_Click"/>
                    <Button x:Name="OdinBtn"
                            Style="{StaticResource ModeButton}"
                            Content="🟡 ODIN"
                            Click="OdinMode_Click"/>
                    <Button x:Name="SideloadBtn"
                            Style="{StaticResource ModeButton}"
                            Content="🟢 SIDELOAD"
                            Click="SideloadMode_Click"/>
                    <Button x:Name="ToolsBtn"
                            Style="{StaticResource ModeButton}"
                            Content="🔧 TOOLS"
                            Click="ToolsMode_Click"/>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="DEVICE:"
                               Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <TextBlock x:Name="DeviceStatusText"
                               Text="NOT CHECKED"
                               Foreground="Gray"
                               FontSize="13"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Margin="0,0,14,0"/>
                    <Button Style="{StaticResource ActionButton}"
                            Background="{DynamicResource AccentSoftBrush}"
                            BorderBrush="{DynamicResource AccentBrush}"
                            Foreground="#EAF4FF"
                            Content="🔍 SCAN DEVICE"
                            Padding="12,6"
                            Click="DetectDevice_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="16,12,8,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Style="{StaticResource ModeButton}"
                            Content="📟 CMD"
                            Click="TabCmd_Click"
                            Padding="12,6"/>
                    <Button Style="{StaticResource ModeButton}"
                            Content="⚙️ OPTIONS"
                            Click="TabOptions_Click"
                            Padding="12,6"/>
                </StackPanel>

                <Grid x:Name="TabCmdPanel" Grid.Row="1">
                    <StackPanel x:Name="PanelFastboot" Visibility="Visible">
                        <TextBlock Text="⚡ FASTBOOT FLASH"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}"
                                   Margin="0,0,0,10"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="380">
                            <ItemsControl x:Name="RowsList" ItemTemplate="{StaticResource FastbootRowTemplate}"/>
                        </ScrollViewer>
                        <Button Style="{StaticResource ActionButton}"
                                Background="{DynamicResource AccentSoftBrush}"
                                BorderBrush="{DynamicResource AccentBrush}"
                                Foreground="#EAF4FF"
                                Content="⚡ FLASH ALL PARTITIONS"
                                Padding="16,9"
                                FontSize="14"
                                Margin="0,10,0,0"
                                HorizontalAlignment="Stretch"
                                Click="FlashAll_Click"/>
                    </StackPanel>

                    <StackPanel x:Name="PanelOdin" Visibility="Collapsed">
                        <TextBlock Text="🟡 ODIN FLASH (ekoflash)"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}"
                                   Margin="0,0,0,10"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="380">
                            <ItemsControl x:Name="OdinRowsList" ItemTemplate="{StaticResource OdinRowTemplate}"/>
                        </ScrollViewer>
                        <Button Style="{StaticResource ActionButton}"
                                Background="{DynamicResource AccentSoftBrush}"
                                BorderBrush="{DynamicResource AccentBrush}"
                                Foreground="#EAF4FF"
                                Content="🟡 FLASH WITH EKOFLASH"
                                Padding="16,9"
                                FontSize="14"
                                Margin="0,10,0,0"
                                HorizontalAlignment="Stretch"
                                Click="FlashAll_Click"/>
                    </StackPanel>

                    <StackPanel x:Name="PanelSideload" Visibility="Collapsed">
                        <TextBlock Text="🟢 ADB SIDELOAD"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}"
                                   Margin="0,0,0,10"/>
                        <Border Style="{StaticResource GlassPanel}" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="70"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="ZIP FILE"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentBrush}"
                                           VerticalAlignment="Center"
                                           FontSize="13"/>
                                <TextBox Grid.Column="1"
                                         x:Name="SideloadPathBox"
                                         Style="{StaticResource PathBox}"
                                         IsReadOnly="True"
                                         Margin="6,0"/>
                                <Button Grid.Column="2"
                                        Style="{StaticResource BrowseBtn}"
                                        Content="📂"
                                        Tag="sideload"
                                        Height="28"
                                        Width="60"
                                        Click="Browse_Click"/>
                            </Grid>
                        </Border>
                        <Button Style="{StaticResource ActionButton}"
                                Background="{DynamicResource AccentSoftBrush}"
                                BorderBrush="{DynamicResource AccentBrush}"
                                Foreground="#EAF4FF"
                                Content="🟢 START SIDELOAD"
                                Padding="16,9"
                                FontSize="14"
                                HorizontalAlignment="Stretch"
                                Click="FlashAll_Click"/>
                    </StackPanel>

                    <StackPanel x:Name="PanelTools" Visibility="Collapsed">
                        <TextBlock Text="🔧 TOOLS &amp; CUSTOM COMMANDS"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}"
                                   Margin="0,0,0,10"/>

                        <Border Style="{StaticResource GlassPanel}" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Custom Command:"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           FontSize="12"
                                           Margin="0,0,0,6"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="CustomCommandBox"
                                             Grid.Column="0"
                                             Style="{StaticResource PathBox}"
                                             Margin="0,0,8,0"/>
                                    <Button Grid.Column="1"
                                            Style="{StaticResource ActionButton}"
                                            Background="{DynamicResource AccentSoftBrush}"
                                            BorderBrush="{DynamicResource AccentBrush}"
                                            Foreground="#EAF4FF"
                                            Content="▶ RUN"
                                            Padding="12,6"
                                            Click="RunCustomCommand_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource GlassPanel}">
                            <WrapPanel>
                                <Button Style="{StaticResource ActionButton}"
                                        Background="#1A3fb950" BorderBrush="#3fb950"
                                        Foreground="#3fb950"
                                        Content="ADB Reboot"
                                        Tag="adb reboot"
                                        Padding="10,5" Margin="0,0,6,6"
                                        Click="RunCustomCommand_Click"/>
                                <Button Style="{StaticResource ActionButton}"
                                        Background="#1A79c0ff" BorderBrush="#79c0ff"
                                        Foreground="#79c0ff"
                                        Content="Reboot Bootloader"
                                        Tag="adb reboot bootloader"
                                        Padding="10,5" Margin="0,0,6,6"
                                        Click="RunCustomCommand_Click"/>
                                <Button Style="{StaticResource ActionButton}"
                                        Background="#1Affa657" BorderBrush="#ffa657"
                                        Foreground="#ffa657"
                                        Content="Reboot Recovery"
                                        Tag="adb reboot recovery"
                                        Padding="10,5" Margin="0,0,6,6"
                                        Click="RunCustomCommand_Click"/>
                                <Button Style="{StaticResource ActionButton}"
                                        Background="#1Af78166" BorderBrush="#f78166"
                                        Foreground="#f78166"
                                        Content="Fastboot Reboot"
                                        Tag="fastboot reboot"
                                        Padding="10,5" Margin="0,0,6,6"
                                        Click="RunCustomCommand_Click"/>
                                <Button Style="{StaticResource ActionButton}"
                                        Background="#1A58a6ff" BorderBrush="#58a6ff"
                                        Foreground="#58a6ff"
                                        Content="ADB Devices"
                                        Tag="adb devices"
                                        Padding="10,5" Margin="0,0,6,6"
                                        Click="RunCustomCommand_Click"/>
                                <Button Style="{StaticResource ActionButton}"
                                        Background="#1A58a6ff" BorderBrush="#58a6ff"
                                        Foreground="#58a6ff"
                                        Content="Fastboot Devices"
                                        Tag="fastboot devices"
                                        Padding="10,5" Margin="0,0,0,6"
                                        Click="RunCustomCommand_Click"/>
                            </WrapPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <Grid x:Name="TabOptionsPanel" Grid.Row="1" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="⚙️ OPTIONS"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}"
                                   Margin="0,0,0,10"/>
                        <Border Style="{StaticResource GlassPanel}" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Flash Options"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Margin="0,0,0,10"/>
                                <CheckBox Content="Skip verification after flash" Foreground="#EAF4FF" Margin="0,0,0,6"/>
                                <CheckBox Content="Wipe userdata before flashing" Foreground="#EAF4FF" Margin="0,0,0,6"/>
                                <CheckBox Content="Auto-reboot after flash" Foreground="#EAF4FF" Margin="0,0,0,6"/>
                                <CheckBox Content="Verbose output" Foreground="#EAF4FF"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource GlassPanel}">
                            <StackPanel>
                                <TextBlock Text="System Info"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Margin="0,0,0,10"/>
                                <TextBlock Text="ADB / Fastboot / ekoflash status will be shown in the log on startup."
                                           Foreground="#9CC7E8"
                                           FontSize="11"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Grid>

            <Border Grid.Column="1"
                    Style="{StaticResource GlassPanel}"
                    Margin="8,12,16,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="📋 COMMAND PREVIEW"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}"
                               Margin="0,0,0,8"/>
                    <TextBox Grid.Row="1"
                             x:Name="CommandPreviewBox"
                             Background="#0A1020"
                             Foreground="#7ee787"
                             BorderThickness="1"
                             BorderBrush="{DynamicResource BorderBrush}"
                             FontFamily="Consolas"
                             FontSize="12"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             AcceptsReturn="True"
                             Padding="10"/>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3"
                Background="#0A1020"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,1"
                Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ProgressBar x:Name="MainProgress"
                             Grid.Column="0"
                             Minimum="0"
                             Maximum="100"
                             Value="0"
                             Height="16"
                             Foreground="{DynamicResource AccentBrush}"
                             Background="#1A2A3A"/>
                <TextBlock x:Name="ProgressStatusText"
                           Grid.Column="1"
                           Text="Ready."
                           Foreground="{DynamicResource TextMutedBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="14,0,0,0"/>
            </Grid>
        </Border>

        <Border Grid.Row="4"
                Background="#060E1A"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#0A1525"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="14,5">
                    <TextBlock Text="📟 LOG OUTPUT"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}"/>
                </Border>

                <TextBox x:Name="LogBox"
                         Grid.Row="1"
                         Background="Transparent"
                         Foreground="#9FEEFF"
                         BorderThickness="0"
                         FontFamily="Consolas"
                         FontSize="12"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         Padding="14,8"/>
            </Grid>
        </Border>
    </Grid>
</Window>
