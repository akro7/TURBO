<Window x:Class="MKVenomTool.UI.ThemeSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Theme Settings"
        Width="460"
        Height="300"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource MainBgBrush}"
        Foreground="{DynamicResource FgBright}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="12" CornerRadius="10"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1.2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Text="Theme"/>
                <ComboBox x:Name="ThemeCombo" Grid.Column="1" Height="30"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Padding="12" CornerRadius="10"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1.2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Text="Mode"/>
                <ComboBox x:Name="ModeCombo" Grid.Column="1" Height="30"/>
            </Grid>
        </Border>

        <Border Grid.Row="4" Padding="12" CornerRadius="10"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1.2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Text="Accent"/>
                <ComboBox x:Name="AccentCombo" Grid.Column="1" Height="30"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="90" Height="34" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Apply" Width="90" Height="34"
                    Background="{DynamicResource AccentBrush}"
                    Foreground="Black" FontWeight="Bold"
                    Click="Apply_Click"/>
        </StackPanel>
    </Grid>
</Window>
