<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- macOS-like liquid glass -->
    <SolidColorBrush x:Key="MainBgBrush" Color="#1C2438"/>
    <SolidColorBrush x:Key="PanelBrush" Color="#55FFFFFF"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#88FFFFFF"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#7DD3FC"/>
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#337DD3FC"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#FB7185"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#34D399"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="#D1D5DB"/>

    <SolidColorBrush x:Key="BgRoot" Color="#111827"/>
    <SolidColorBrush x:Key="BgPanel" Color="#66FFFFFF"/>
    <SolidColorBrush x:Key="BgCard" Color="#4DFFFFFF"/>
    <SolidColorBrush x:Key="BgInput" Color="#73FFFFFF"/>
    <SolidColorBrush x:Key="BgHover" Color="#8AFFFFFF"/>
    <SolidColorBrush x:Key="FgBright" Color="#F9FAFB"/>
    <SolidColorBrush x:Key="FgMid" Color="#E5E7EB"/>
    <SolidColorBrush x:Key="FgDim" Color="#9CA3AF"/>

</ResourceDictionary>
