<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>

    <!-- اسم الـ assembly ثابت دايماً -->
    <AssemblyName>EkoFlashTool</AssemblyName>
    <RootNamespace>MKVenomTool</RootNamespace>
    <Product>MK VENOM PRO</Product>

    <!-- معلومات المنتج -->
    <Company>AKRO × MK VENOM PRO</Company>
    <Copyright>Copyright © 2025 akro7 &amp; mkpromvp – GPL-3.0</Copyright>
    <Description>Samsung Official ROM Flashing Tool – Safe &amp; Trusted</Description>
    <Version>1.0.0</Version>
    <FileVersion>1.0.0.0</FileVersion>
    <AssemblyVersion>1.0.0.0</AssemblyVersion>

    <!-- أيقونة التطبيق -->
    <ApplicationIcon>app.ico</ApplicationIcon>

    <!-- Publish settings -->
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <PublishReadyToRun>false</PublishReadyToRun>
  </PropertyGroup>

  <!-- ══ الأدوات المضمنة كـ EmbeddedResource ══
       LogicalName يطابق تماماً ما يبحث عنه ToolsManager.cs -->
  <ItemGroup>

    <!-- platform-tools -->
    <EmbeddedResource Include="adb.exe">
      <LogicalName>res.pt.adb.exe</LogicalName>
    </EmbeddedResource>

    <EmbeddedResource Include="fastboot.exe">
      <LogicalName>res.pt.fastboot.exe</LogicalName>
    </EmbeddedResource>

    <EmbeddedResource Include="AdbWinApi.dll">
      <LogicalName>res.pt.AdbWinApi.dll</LogicalName>
    </EmbeddedResource>

    <EmbeddedResource Include="AdbWinUsbApi.dll">
      <LogicalName>res.pt.AdbWinUsbApi.dll</LogicalName>
    </EmbeddedResource>

    <!-- odin backend – يتولد من C++ build في CI -->
    <EmbeddedResource Include="ekoflash.exe" Condition="Exists('ekoflash.exe')">
      <LogicalName>res.ok.ekoflash.exe</LogicalName>
    </EmbeddedResource>

    <!-- libusb -->
    <EmbeddedResource Include="libusb-1.0.dll" Condition="Exists('libusb-1.0.dll')">
      <LogicalName>res.ok.libusb.dll</LogicalName>
    </EmbeddedResource>

    <!-- zadig -->
    <EmbeddedResource Include="zadig.exe" Condition="Exists('zadig.exe')">
      <LogicalName>res.zd.zadig.exe</LogicalName>
    </EmbeddedResource>

    <!-- أيقونة التطبيق -->
    <Resource Include="app.ico" Condition="Exists('app.ico')"/>

  </ItemGroup>

</Project>
